# Meta Ads Agent — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env no repositório

# Token de acesso à Meta Graph API
# Obtenha em: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=your_access_token_here

# ID da conta de anúncios (formato: act_XXXXXXXXX)
# Encontre em: Meta Business Manager > Contas de Anúncios
META_AD_ACCOUNT_ID=act_your_ad_account_id_here

# ID do aplicativo Meta
# Encontre em: https://developers.facebook.com/apps/
META_APP_ID=your_app_id_here

# Chave secreta do aplicativo Meta
# Encontre em: https://developers.facebook.com/apps/ > Configurações > Básico
META_APP_SECRET=your_app_secret_here

# ID da página do Facebook (opcional, mas recomendado)
# Necessário para criar criativos
META_PAGE_ID=your_page_id_here
