# Meta Ads Agent — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env no repositório

# ─────────────────────────────────────────────
# Autenticação da aplicação web
# ─────────────────────────────────────────────

# Senha de acesso à interface web
AUTH_PASSWORD=sua_senha_aqui

# Chave secreta para assinar os JWTs (mínimo 32 caracteres)
AUTH_SECRET=chave_secreta_min_32_caracteres_aqui!!

# ─────────────────────────────────────────────
# Anthropic (Claude AI)
# ─────────────────────────────────────────────

# Chave de API da Anthropic para o agente de chat
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# Meta API (credenciais por cliente em clients.json)
# ─────────────────────────────────────────────
# As credenciais Meta (access_token, ad_account_id, app_id, app_secret, page_id)
# são armazenadas por cliente no arquivo clients.json (nunca commitado).
# Use clients.example.json como template.
#
# Variáveis globais Meta (opcional, usadas como fallback)
META_ACCESS_TOKEN=your_access_token_here
META_AD_ACCOUNT_ID=act_your_ad_account_id_here
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here
META_PAGE_ID=your_page_id_here
